{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "lib": ["ES2022"],
    "isolatedModules": true,
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*", "test/*"]
    }
  },
  "exclude": [
    "node_modules",
    "public_html",
    "test",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
